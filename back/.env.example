# 운영 환경에서는 반드시 임의의 긴 문자열로 교체한다.
YEON_SECRET_KEY=dev-secret-change-me
YEON_DATABASE_URL=sqlite:///./yeon.db
YEON_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 시작 시 데모 데이터(계정, 인연 방, 채팅)를 넣는다.
YEON_SEED_DEMO_DATA=true

# --- 분석 엔진 -------------------------------------------------------------
# mock  = 규칙 기반 목업 (키 불필요, 결정적, 무료)
# agent = Anthropic API 기반 4개 에이전트
YEON_ANALYSIS_ENGINE=mock

# agent 엔진에서만 필요하다. 비워 두면 SDK가 ANTHROPIC_API_KEY 환경변수를 찾는다.
YEON_ANTHROPIC_API_KEY=
YEON_ANTHROPIC_MODEL=claude-opus-4-8

# 에이전트 호출이 실패하면(키 없음, 레이트 리밋, 거절) 규칙 기반으로 떨어진다.
# false로 두면 대신 오류를 그대로 올린다. 개발 중 실패를 숨기고 싶지 않을 때 쓴다.
YEON_ANALYSIS_FALLBACK=true

# 선별 단계에 넘길 후보 상한. 넓게 추리되 토큰이 폭주하지 않게 막는다.
YEON_ANALYSIS_SHORTLIST_SIZE=12
